[
  {"id":"indcolen-001","text":"I prefer to be direct and forthright when I talk with people.","keyed":"plus","domain":"HI","facet":null,"num":1,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-002","text":"My happiness depends very much on the happiness of those around me.","keyed":"plus","domain":"HC","facet":null,"num":2,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-003","text":"I would do what would please my family.","keyed":"plus","domain":"VC","facet":null,"num":3,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-004","text":"Winning is everything.","keyed":"plus","domain":"VI","facet":null,"num":4,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-005","text":"One should live one's life independently of others.","keyed":"plus","domain":"HI","facet":null,"num":5,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-006","text":"What happens to me is my own doing.","keyed":"plus","domain":"HI","facet":null,"num":6,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-007","text":"I usually sacrifice my self-interest for the benefit of my group.","keyed":"plus","domain":"VC","facet":null,"num":7,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-008","text":"It annoys me when others people perform better than I do.","keyed":"plus","domain":"VI","facet":null,"num":8,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-009","text":"It is important for me to maintain harmony within my group.","keyed":"plus","domain":"HC","facet":null,"num":9,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-010","text":"It is important for me that I do my job better than the others.","keyed":"plus","domain":"VI","facet":null,"num":10,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-011","text":"I like sharing little things with my neighbors.","keyed":"plus","domain":"HC","facet":null,"num":11,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-012","text":"I enjoy working in situations involving competition with others.","keyed":"plus","domain":"VI","facet":null,"num":12,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-013","text":"We should keep our aging parents with us at home.","keyed":"plus","domain":"VC","facet":null,"num":13,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-014","text":"The wellbeing of my coworkers is important to me.","keyed":"plus","domain":"HC","facet":null,"num":14,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-015","text":"I enjoy being unique and different from the others in many ways.","keyed":"plus","domain":"HI","facet":null,"num":15,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-016","text":"If a relative were in financial difficulty, I would help within my means.","keyed":"plus","domain":"VC","facet":null,"num":16,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-017","text":"Children should feel honored if their parents receive a distinguished award.","keyed":"plus","domain":"VC","facet":null,"num":17,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-018","text":"I often do my own thing.","keyed":"plus","domain":"HI","facet":null,"num":18,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-019","text":"Competition is law of nature.","keyed":"plus","domain":"VI","facet":null,"num":19,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-020","text":"If a co-worker gets a price I would feel proud.","keyed":"plus","domain":"HC","facet":null,"num":20,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-021","text":"I am a unique individual.","keyed":"plus","domain":"HI","facet":null,"num":21,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-022","text":"To me pleasure is spending time with others.","keyed":"plus","domain":"HC","facet":null,"num":22,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-023","text":"When another person does better than I do, I get tense and aroused.","keyed":"plus","domain":"VI","facet":null,"num":23,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-024","text":"I would sacrifice an activity that I enjoy very much if my family did not approve of it.","keyed":"plus","domain":"VC","facet":null,"num":24,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-025","text":"I like my privacy.","keyed":"plus","domain":"HI","facet":null,"num":25,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-026","text":"Without competition it is impossible to have a good society.","keyed":"plus","domain":"VI","facet":null,"num":26,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-027","text":"Children should be taught to place duty before pleasure.","keyed":"plus","domain":"VC","facet":null,"num":27,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-028","text":"I feel good when I cooperate with others.","keyed":"plus","domain":"HC","facet":null,"num":28,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-029","text":"I hate to disagree with others in my group.","keyed":"plus","domain":"VC","facet":null,"num":29,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-030","text":"Some people emphasize winning; I am not one of them.","keyed":"minus","domain":"VI","facet":null,"num":30,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-031","text":"Before making a major trip, I consult with most members of my family and many friends.","keyed":"plus","domain":"HC","facet":null,"num":31,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]},
  {"id":"indcolen-032","text":"When I succeeded, it is usually because of my abilities.","keyed":"plus","domain":"HI","facet":null,"num":32,"choices":[{"text":"Strongly disagree","score":1},{"text":"Somewhat disagree","score":2},{"text":"Slightly disagree","score":3},{"text":"Neutral","score":4},{"text":"Slightly agree","score":5},{"text":"Somewhat agree","score":6},{"text":"Strongly agree","score":7}]}
]
